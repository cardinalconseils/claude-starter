#!/bin/bash
# Auto-bump version on every commit
# Runs scripts/bump-version.sh and stages the updated version files
#
# Install: cp scripts/hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
# Or run:  scripts/install-hooks.sh

REPO_ROOT="$(git rev-parse --show-toplevel)"
BUMP_SCRIPT="$REPO_ROOT/scripts/bump-version.sh"
PLUGIN_JSON="$REPO_ROOT/.claude-plugin/plugin.json"

if [ ! -f "$BUMP_SCRIPT" ]; then
  exit 0
fi

# Idempotency check: if the staged version already differs from HEAD, a manual
# bump was run before this commit — skip to avoid a double bump.
if [ -f "$PLUGIN_JSON" ]; then
  HEAD_VERSION=$(git show HEAD:"$REPO_ROOT/.claude-plugin/plugin.json" 2>/dev/null | grep '"version"' | sed 's/.*"version": *"\([^"]*\)".*/\1/')
  STAGED_VERSION=$(git show :"$REPO_ROOT/.claude-plugin/plugin.json" 2>/dev/null | grep '"version"' | sed 's/.*"version": *"\([^"]*\)".*/\1/')
  # Use relative path for git show (git show requires repo-relative paths)
  HEAD_VERSION=$(git show HEAD:.claude-plugin/plugin.json 2>/dev/null | grep '"version"' | sed 's/.*"version": *"\([^"]*\)".*/\1/')
  STAGED_VERSION=$(git show :.claude-plugin/plugin.json 2>/dev/null | grep '"version"' | sed 's/.*"version": *"\([^"]*\)".*/\1/')
  if [ -n "$HEAD_VERSION" ] && [ -n "$STAGED_VERSION" ] && [ "$HEAD_VERSION" != "$STAGED_VERSION" ]; then
    echo "Version already bumped to $STAGED_VERSION (skipping auto-bump)"
    exit 0
  fi
fi

# Run the bump script
NEW_VERSION=$(bash "$BUMP_SCRIPT" 2>/dev/null)

if [ -z "$NEW_VERSION" ]; then
  exit 0
fi

# Stage the version files that were updated
git add \
  "$REPO_ROOT/.claude-plugin/plugin.json" \
  "$REPO_ROOT/.claude-plugin/marketplace.json" \
  "$REPO_ROOT/README.md" \
  "$REPO_ROOT/docs/WORKFLOW.md" \
  2>/dev/null

echo "Version bumped to $NEW_VERSION"
