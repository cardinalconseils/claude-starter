#!/bin/bash
# Auto-bump version on every commit
# Runs scripts/bump-version.sh and stages the updated version files
#
# Install: cp scripts/hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
# Or run:  scripts/install-hooks.sh

REPO_ROOT="$(git rev-parse --show-toplevel)"
BUMP_SCRIPT="$REPO_ROOT/scripts/bump-version.sh"
PLUGIN_JSON="$REPO_ROOT/.claude-plugin/plugin.json"

if [ ! -f "$BUMP_SCRIPT" ]; then
  exit 0
fi

# Idempotency check: if VERSION in working tree already differs from HEAD,
# bump-version.sh was already run — skip to avoid a double bump.
VERSION_FILE="$REPO_ROOT/VERSION"
if [ -f "$VERSION_FILE" ]; then
  HEAD_VERSION=$(git show HEAD:VERSION 2>/dev/null)
  CUR_VERSION=$(cat "$VERSION_FILE" 2>/dev/null)
  if [ -n "$HEAD_VERSION" ] && [ -n "$CUR_VERSION" ] && [ "$HEAD_VERSION" != "$CUR_VERSION" ]; then
    echo "Version already bumped to $CUR_VERSION (skipping auto-bump)"
    git add \
      "$REPO_ROOT/.claude-plugin/plugin.json" \
      "$REPO_ROOT/.claude-plugin/marketplace.json" \
      "$REPO_ROOT/VERSION" \
      "$REPO_ROOT/CHANGELOG.md" \
      "$REPO_ROOT/README.md" \
      "$REPO_ROOT/docs/WORKFLOW.md" \
      "$REPO_ROOT/docs/wiki/README.md" \
      2>/dev/null
    exit 0
  fi
fi

# Run the bump script
NEW_VERSION=$(bash "$BUMP_SCRIPT" 2>/dev/null)

if [ -z "$NEW_VERSION" ]; then
  exit 0
fi

# Stage the version files that were updated
git add \
  "$REPO_ROOT/.claude-plugin/plugin.json" \
  "$REPO_ROOT/.claude-plugin/marketplace.json" \
  "$REPO_ROOT/VERSION" \
  "$REPO_ROOT/CHANGELOG.md" \
  "$REPO_ROOT/README.md" \
  "$REPO_ROOT/docs/WORKFLOW.md" \
  "$REPO_ROOT/docs/wiki/README.md" \
  2>/dev/null

echo "Version bumped to $NEW_VERSION"
